{
  "manifest_version": 3,
  "name": "ProScore",
  "version": "3.0.0",
  "description": "Protein product scoring: ProteinScore, ValueScore, ProScore.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "ProScore",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"]
}
